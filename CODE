x\n","    corr_matrix = np.corrcoef(X, rowvar=False)\n","    corr_matrix = np.abs(corr_matrix)\n","\n","    n_features = X.shape[1]\n","\n","    # Find all correlated pairs above threshold (upper triangle only)\n","    mask = (corr_matrix > threshold) & (~np.eye(n_features, dtype=bool))\n","    correlated_pairs = np.argwhere(mask)\n","\n","    # Build graph and find connected components (groups of correlated features)\n","    G = nx.Graph()\n","    G.add_nodes_from(range(n_features))\n","    G.add_edges_from(correlated_pairs)\n","    groups = list(nx.connected_components(G))\n","\n","    to_drop = set()\n","\n","    for group in groups:\n","        # Keep feature with highest SHAP importance\n","        keep = max(group, key=lambda x: shap_importance[x])\n","        drop = group - {keep}\n","        to_drop.update(drop)\n","\n","    # Map indices to feature names\n","    selected_features = [features_columns[i] for i in range(n_features) if i not in to_drop]\n","\n","    return selected_features, groups, to_drop"]},{"cell_type":"code","execution_count":null,"id":"AMMPrvJj9gN9","metadata":{"id":"AMMPrvJj9gN9","executionInfo":{"status":"aborted","timestamp":1767506644061,"user_tz":-480,"elapsed":2478,"user":{"displayName":"Arvir Redondo","userId":"16639262244819388761"}}},"outputs":[],"source":["def drop_correlated_by_shap(df, shap_importance, threshold=0.9):\n","\n","    print('done1')\n","\n","    df = df.astype(float)\n","\n","    print('done2')\n","    corr_matrix = np.corrcoef(df, rowvar=False)\n","\n","    print('done3')\n","    corr_matrix = np.abs(corr_matrix)\n","    # return corr_matrix\n","\n","    print('done4')\n","    # corr_matrix = df.corr().abs()\n","    columns = set(features_columns)\n","\n","    print('done5')\n","    to_drop = set()\n","\n","    print('done6')\n","\n","    # Work on a copy to avoid modifying original\n","    remaining = set(columns)\n","    remaining_index = [features_columns.index(x) for x in remaining]\n","\n","    print('done7'